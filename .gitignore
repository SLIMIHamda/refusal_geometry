results/
cache/
*.parquet
*.sqlite
*.sqlite-journal

# python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/
venv/

# models / weights (never committed)
*.safetensors
*.bin

# Claude Code local settings (machine/user-specific)
.claude/

